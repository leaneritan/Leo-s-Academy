              "levelUp": {
                "title": "Is it...? \u2014 Beyond the Classroom",
                "content": "You already know how to ask 'Is it a pencil?' Great! But we use 'Is it...?' for so many more things in real life. We use it to ask about the weather, about time, about food, about animals, and even about feelings. Any time you want to ask YES or NO about ONE thing \u2014 use 'Is it...?'",
                "categories": [
                  {
                    "label": "About Weather",
                    "color": "bg-blue-100 text-blue-700",
                    "examples": [
                      {
                        "question": "Is it cold today?",
                        "answer": "Yes, it is. Wear your jacket!"
                      },
                      {
                        "question": "Is it raining?",
                        "answer": "No, it isn't. You don't need an umbrella."
                      }
                    ]
                  },
                  {
                    "label": "About Food",
                    "color": "bg-orange-100 text-orange-700",
                    "examples": [
                      {
                        "question": "Is it spicy?",
                        "answer": "Yes, it is. Be careful!"
                      },
                      {
                        "question": "Is it delicious?",
                        "answer": "Yes, it is. I love it!"
                      }
                    ]
                  },
                  {
                    "label": "About Animals",
                    "color": "bg-green-100 text-green-700",
                    "examples": [
                      {
                        "question": "Is it dangerous?",
                        "answer": "No, it isn't. It's friendly."
                      },
                      {
                        "question": "Is it a mammal?",
                        "answer": "Yes, it is. It has fur."
                      }
                    ]
                  },
                  {
                    "label": "About Time",
                    "color": "bg-purple-100 text-purple-700",
                    "examples": [
                      {
                        "question": "Is it time for lunch?",
                        "answer": "Yes, it is. Let's eat!"
                      },
                      {
                        "question": "Is it late?",
                        "answer": "No, it isn't. We have time."
                      }
                    ]
                  },
                  {
                    "label": "About Feelings",
                    "color": "bg-pink-100 text-pink-700",
